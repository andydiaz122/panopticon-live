# Copy this file to .env and fill in real values.

# Required for any Opus/Haiku API calls (Phase 2 onward).
ANTHROPIC_API_KEY=sk-ant-...

# MPS is the default on Mac Mini M4 Pro.
# "cuda" is unused this week; "cpu" for environments without accelerator.
PANOPTICON_DEVICE=mps

# Path to the pre-computed DuckDB file (writable locally; read-only on Vercel).
DUCKDB_PATH=data/panopticon.duckdb

# Local path to UTR tennis clips. These are gitignored.
CLIPS_DIR=data/clips

# YOLO weights cache directory (Ultralytics will download yolo11m-pose.pt here on first run).
YOLO_WEIGHTS_DIR=checkpoints

# FastAPI / uvicorn bind for local dev.
HOST=127.0.0.1
PORT=8000

# Vercel deploy env (do NOT set locally):
# VERCEL_ENV=production
