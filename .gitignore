*.pt
!yolo11m-pose.pt.keep

# Logs
logs/
*.log

# OS
.DS_Store
Thumbs.db

# Claude Code
.claude/sessions/

# (intentionally allow tracked match_data; regenerated by run_golden_data.sh but kept in git for Vercel deploy)
!dashboard/public/match_data/.gitkeep
!dashboard/public/match_data/*.json

# External research PDFs (copyrighted third-party reference material only)
research_sources/
.vercel
.claude/tmp/

# Runtime lock files (PID-bearing, session-scoped — never commit)
.claude/*.lock
